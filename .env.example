# Copy to .env and fill in. Never commit .env.

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token
# Only this Telegram numeric user id may log. Get it from @userinfobot.
ALLOWED_TELEGRAM_ID=

# --- Database (Railway Postgres) ---
# Local: Railway's PUBLIC connection string. On Railway: injected as DATABASE_URL.
DATABASE_URL=postgresql://postgres:password@host:5432/railway

# --- Gemini (free-text agent) ---
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Supabase Auth (Google SSO for the dashboard; no app data stored here) ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
# Comma-separated allowlist; only these emails may sign in to the dashboard.
# Real values are set as Railway env vars only — never committed here.
ALLOWED_EMAILS=someone@example.com,someone-else@example.com
# Signs the login session cookie. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=

# --- Patient / schedule ---
PATIENT_NAME=Glauber Machado
TIMEZONE=America/Sao_Paulo
# 24h HH:MM, comma-separated
BASAGLAR_TIME=21:00
COLIRIO_TIMES=08:00,14:00,20:00
COLIRIO_PRODUCT=binadeprosto

# --- Web ---
PORT=8000
